# Web frontend - multi-stage build
# Build context: project root

# Stage 1: Build web assets
FROM node:20-alpine AS builder

RUN npm install -g pnpm@9.15.0

WORKDIR /app

ARG VITE_API_BASE_URL=http://localhost:4000
ENV VITE_API_BASE_URL=$VITE_API_BASE_URL

# Copy package files
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY apps/api/package.json ./apps/api/
COPY apps/web/package.json ./apps/web/
COPY packages/shared/package.json ./packages/shared/

RUN pnpm install --frozen-lockfile

COPY . .

# Generate Prisma (needed for shared types resolution)
RUN pnpm prisma:generate

# Build shared and web
RUN pnpm --filter @hots-monitor/shared build
RUN pnpm --filter @hots-monitor/web build

# Stage 2: Serve with nginx
FROM nginx:alpine AS production

COPY --from=builder /app/apps/web/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf
