API_PORT=4000
WEB_ORIGIN=http://localhost:5173

# SQLite database is stored in the Docker volume by default.
DATABASE_URL=file:/app/data/prod.db

# DeepSeek AI
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_STRICT_MODEL=deepseek-v4-pro

# RSSHub / X
RSSHUB_BASE_URL=https://rsshub.app
X_BEARER_TOKEN=

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_TO=

# Scheduler intervals
KEYWORD_INTERVAL_MINUTES=10
TRENDS_INTERVAL_MINUTES=60
