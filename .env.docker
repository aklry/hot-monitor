# Docker Deployment Environment Variables
# Copy this file to .env and fill in your values

# DeepSeek AI Configuration (Required)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_STRICT_MODEL=deepseek-v4-pro

# RSSHub Configuration (Optional)
# Default: http://rsshub:1200 (uses the RSSHub container)
RSSHUB_BASE_URL=http://rsshub:1200

# X/Twitter Bearer Token (Optional)
X_BEARER_TOKEN=

# SMTP Configuration (Optional - for email notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_TO=

# Scheduler Intervals (Optional)
KEYWORD_INTERVAL_MINUTES=10
TRENDS_INTERVAL_MINUTES=60
